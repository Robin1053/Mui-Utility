{
  "name": "@robineb/mui-utility",
  "version": "1.0.1",
  "description": "Utility extensions for MUI",
  "keywords": [
    "mui",
    "utility"
  ],
  "homepage": "https://github.com/Robin1053/Mui-Utility#readme",
  "bugs": {
    "url": "https://github.com/Robin1053/Mui-Utility/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Robin1053/Mui-Utility.git"
  },
  "license": "MIT",
  "author": "robin1053",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "@mui/material": "^5 || ^6 || ^7",
    "@emotion/react": "^11",
    "@emotion/styled": "^11"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
