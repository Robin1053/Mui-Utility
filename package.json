{
  "name": "@robineb/mui-utility",
  "version": "1.1.2",
  "description": "Utility extensions for MUI",
  "keywords": [
    "mui",
    "utility"
  ],
  "homepage": "https://github.com/Robin1053/Mui-Utility#readme",
  "bugs": {
    "url": "https://github.com/Robin1053/Mui-Utility/issues",
    "email": "robineb174@gmx.de"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Robin1053/Mui-Utility.git"
  },
  "license": "MIT",
  "author": "robin1053",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.mjs",
      "require": "./dist/*/index.js"
    },
    "./*/*": {
      "types": "./dist/*/*/index.d.ts",
      "import": "./dist/*/*/index.mjs",
      "require": "./dist/*/*/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup \"src/**/index.ts\" --format cjs,esm --dts --clean",
    "dev": "tsup \"src/**/index.ts\" --format cjs,esm --dts --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:vite": "node scripts/test-vite.mjs"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "ts-node": "^10.9.2",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^5 || ^6 || ^7",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
